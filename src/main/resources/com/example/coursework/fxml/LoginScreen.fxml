<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="root-vbox" alignment="CENTER" prefWidth="300.0" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@../styles/LoginScreen.css" fx:controller="com.example.coursework.controllers.LoginController">
    <VBox styleClass="content-vbox">
        <Label styleClass="header" fx:id="storeNameLabel" text="RETAIL MANAGEMENT SYSTEM" />
        <TextField styleClass="input" fx:id="usernameField" promptText="Username" />
        <PasswordField styleClass="input" fx:id="passwordField" maxWidth="Infinity" promptText="Password" />
    </VBox>
    <VBox styleClass="login-vbox">
        <Button styleClass="login-button" maxWidth="Infinity" onAction="#handleLogin" text="Login"/>
        <Label styleClass="error-label" fx:id="errorLabel" visible="false"/>
        <Button fx:id="insertSampleDataBtn" styleClass="login-button" onAction="#insertSampleData" text="Insert Sample Data"/>
    </VBox>
</VBox>
